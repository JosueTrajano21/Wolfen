<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wolfen_laranja">

    <ImageButton
        android:id="@+id/btnFechar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/fechar"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/wolfen_texto_preto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTransferirPara"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="34dp"
        android:text="@string/transferir_para"
        android:textColor="@color/wolfen_texto_preto"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnFechar" />

    <EditText
        android:id="@+id/edtDestinatario"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="55dp"
        android:background="@drawable/bg_campo_branco"
        android:hint="@string/nome_cpf_cnpj"
        android:inputType="text"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:singleLine="true"
        android:textColor="@color/wolfen_texto_preto"
        android:textColorHint="@color/wolfen_texto_hint"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTransferirPara" />

    <Button
        android:id="@+id/btnContinuar"
        android:layout_width="150dp"
        android:layout_height="58dp"
        android:background="@drawable/bg_botao_preto"
        android:backgroundTint="@null"
        android:text="@string/continuar"
        android:textAllCaps="false"
        android:textColor="@color/wolfen_branco"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtDestinatario"
        app:layout_constraintVertical_bias="0.72" />

</androidx.constraintlayout.widget.ConstraintLayout>