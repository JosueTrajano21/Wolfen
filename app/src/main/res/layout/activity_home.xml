<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wolfen_branco"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Cabeçalho -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:background="@color/wolfen_laranja"
            android:paddingStart="28dp"
            android:paddingTop="34dp"
            android:paddingEnd="28dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="60dp"
                android:layout_height="53dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:src="@drawable/wolf_head_logo_icon_geometric_260nw_2583162395_photoroom"
                android:tint="@color/wolfen_preto" />

            <ImageView
                android:id="@+id/imgNotificacao"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_notificacao"
                android:tint="@color/wolfen_preto" />

            <TextView
                android:id="@+id/txtSaudacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="34dp"
                android:text="Olá, Josué"
                android:textColor="@color/wolfen_texto_preto"
                android:textSize="22sp" />

        </RelativeLayout>

        <!-- Saldo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="330dp"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="44dp"
            android:paddingEnd="28dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saldo disponível"
                    android:textColor="@color/wolfen_texto_preto"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgOlho"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="10dp"
                    android:src="@drawable/ic_olho"
                    android:tint="@color/wolfen_preto" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="R$ 12.450,80"
                android:textColor="@color/wolfen_texto_preto"
                android:textSize="23sp"
                android:textStyle="bold" />

            <!-- Ações -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circulo_laranja"
                        android:padding="13dp"
                        android:src="@drawable/ic_transferir"
                        android:tint="@color/wolfen_preto" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Transferir"
                        android:textColor="@color/wolfen_texto_preto"
                        android:textSize="15sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circulo_laranja"
                        android:padding="13dp"
                        android:src="@drawable/ic_boleto"
                        android:tint="@color/wolfen_preto" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Pagar Boleto"
                        android:textColor="@color/wolfen_texto_preto"
                        android:textSize="15sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circulo_laranja"
                        android:padding="13dp"
                        android:src="@drawable/ic_emprestimo"
                        android:tint="@color/wolfen_preto" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Empréstimo"
                        android:textColor="@color/wolfen_texto_preto"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Cartão -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/wolfen_laranja"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="34dp"
            android:paddingEnd="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cartão"
                android:textColor="@color/wolfen_texto_preto"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Fatura Atual"
                android:textColor="@color/wolfen_texto_preto"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 250,05"
                android:textColor="@color/wolfen_texto_preto"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/btnPagar"
                android:layout_width="110dp"
                android:layout_height="40dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_botao_vermelho"
                android:gravity="center"
                android:text="PAGAR"
                android:textColor="@color/wolfen_texto_preto"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>